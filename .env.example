# Root environment variables (if needed)
# Backend will use backend/.env.example
# Frontend will use frontend/.env.local

# Database (shared)
DATABASE_URL="postgresql://user:password@localhost:5432/voiceagent?schema=public"

# Redis (shared)
REDIS_HOST=localhost
REDIS_PORT=6379

# API URLs
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
